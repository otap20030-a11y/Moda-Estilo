rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields: uid, displayName, photoURL, email
    //
    // Collection: clothing
    // Fields: id, userId, image, category, timestamp, isPublic, userName, userPhoto
    //
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.keys().hasOnly(['uid', 'email', 'displayName', 'photoURL']) &&
             data.uid is string && data.uid == request.auth.uid &&
             data.email is string && data.email.size() < 256 &&
             (!('displayName' in data) || (data.displayName == null || (data.displayName is string && data.displayName.size() < 100))) &&
             (!('photoURL' in data) || (data.photoURL == null || (data.photoURL is string && data.photoURL.size() < 1000)));
    }

    function isValidClothing(data) {
      return data.keys().hasAll(['userId', 'image', 'timestamp']) &&
             data.keys().hasOnly(['userId', 'image', 'timestamp', 'category', 'isPublic', 'userName', 'userPhoto']) &&
             data.userId is string && data.userId == request.auth.uid &&
             data.image is string && data.image.size() < 1000000 &&
             data.timestamp is number &&
             (!('category' in data) || (data.category is string && data.category.size() < 50)) &&
             (!('isPublic' in data) || data.isPublic is bool) &&
             (!('userName' in data) || (data.userName is string && data.userName.size() < 100)) &&
             (!('userPhoto' in data) || (data.userPhoto is string && data.userPhoto.size() < 1000));
    }

    function isAuthorizedUploader() {
      return isAuthenticated() && request.auth.token.email == "ramon39261@gmail.com";
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create, update: if isOwner(userId) && isValidUser(request.resource.data);
    }

    match /clothing/{clothingId} {
      allow read: if resource.data.isPublic == true || (isAuthenticated() && resource.data.userId == request.auth.uid);

      allow create: if isAuthorizedUploader() && isValidClothing(request.resource.data);
                      
      allow update: if isDocOwner() && 
                      isValidClothing(request.resource.data) &&
                      request.resource.data.userId == resource.data.userId;
                      
      allow delete: if isDocOwner();
    }
  }
}
